    "Korunak binasını yükselt → daha az yağmalanırsın.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Upgrade the Bunker → get raided less."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bunker verbessern → weniger Plünderung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mejora el Búnker → te saquean menos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Améliore le Bunker → moins de pillage."
          }
        },
        "it": {
