    "İleri birlikler eğitmeden önce burada araştırılmalı.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Advanced troops must be researched here before training."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fortgeschrittene Truppen müssen hier erforscht werden, bevor sie ausgebildet werden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les troupes avancées doivent être recherchées ici avant l'entraînement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las tropas avanzadas deben investigarse aquí antes de entrenarlas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le truppe avanzate vanno ricercate qui prima di addestrarle."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tropas avançadas devem ser pesquisadas aqui antes de treiná-las."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перед обучением продвинутых войск это нужно исследовать здесь."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "上級部隊を訓練する前に、ここで研究が必要。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قبل تدريب الوحدات المتقدّمة يجب بحثها هنا."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "상위 병력을 훈련하려면 먼저 여기서 연구해야 합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
