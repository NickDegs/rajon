    "Sahaya en fazla 4 adam çıkar. Aşağıdan seç.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Field up to 4 men. Pick below."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bis zu 4 Männer einsetzen. Unten wählen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Despliega hasta 4 hombres. Elige abajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déploie jusqu'à 4 hommes. Choisis ci-dessous."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Schiera fino a 4 uomini. Scegli sotto."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloque até 4 homens. Escolha abaixo."
          }
        },
        "ru": {
