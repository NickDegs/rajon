            "state": "translated",
            "value": "Выстави до 4 бойцов. Выбери ниже."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انشر حتى 4 رجال. اختر بالأسفل."
          }
        },
        "ja": {
