    "Kahraman macerada — savaşta yok": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hero on an adventure — not in the fight"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Held auf Abenteuer — nicht im Kampf"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Héros en aventure — absent du combat"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El héroe está en aventura — no en batalla"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'eroe è in avventura — non in battaglia"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O herói está em aventura — fora da batalha"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Герой в приключении — не в бою"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ヒーローは冒険中 — 戦闘に不在"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "البطل في مغامرة — غائب عن المعركة"
          }
        },
        "ko": {
          "stringUnit": {
