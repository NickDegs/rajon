          "stringUnit": {
            "state": "translated",
            "value": "Zahl und zieh einen von der Straße. Mal Köter, mal Legende — Glückssache."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Paga y saca un hombre de la calle. Unos perros, otros leyendas — suerte."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Paie et tire un homme de la rue. Parfois un cabot, parfois une légende — au hasard."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Paga e tira su un uomo dalla strada. Chi è un cane, chi una leggenda — fortuna."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pague e puxe um homem da rua. Uns são vira-latas, outros lendas — sorte."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Плати и тащи бойца с улицы. Кто шавка, кто легенда — как повезёт."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ادفع واسحب رجلاً من الشارع. منهم وضيع ومنهم أسطورة — حظّك."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "金を払い、街から男を引く。雑魚か伝説か — 運次第。"
          }
        }
      }
    },
