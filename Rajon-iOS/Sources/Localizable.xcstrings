            "state": "translated",
            "value": "Treine tropas, depois ataque."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сначала обучи бойцов, потом набег."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "درّب الجنود أولاً ثم اغزُ."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まず兵を訓練、それから襲撃。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "먼저 병사를 훈련하고, 그다음 습격에 나서세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先训练士兵，再出击袭击。"
          }
        }
      }
    },
    "Önce Ekip'ten sahaya adam koy.": {
