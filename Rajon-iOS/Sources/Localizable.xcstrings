    "Henüz başka oyuncu yok. Sen ilk reissin.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No other players yet. You're the first boss."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine anderen Spieler. Du bist der erste Boss."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay otros jugadores. Eres el primer jefe."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore d'autres joueurs. Tu es le premier boss."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun altro giocatore. Sei il primo boss."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum outro jogador ainda. Você é o primeiro chefe."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Других игроков пока нет. Ты первый босс."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا لاعبين بعد. أنت الزعيم الأول."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "他のプレイヤーはまだいない。あなたが最初のボス。"
          }
        }
      }
    },
    "Henüz çete yok. İlk çeteyi sen kur.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No gangs yet. Found the first one."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Banden. Gründe die erste."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay bandas. Funda la primera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore de gang. Fonde le premier."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuna banda. Fonda la prima."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma gangue ainda. Funde a primeira."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Банд пока нет. Создай первую."
          }
        },
