    "Kültür puanı bina seviyelerinden ve kutlamalardan gelir; yeni köy kurmak için gerekir.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Culture points come from building levels and celebrations; needed to found new villages."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kulturpunkte stammen aus Gebäudestufen und Feiern; nötig, um neue Dörfer zu gründen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les points de culture proviennent des niveaux de bâtiments et des célébrations ; nécessaires pour fonder de nouveaux villages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los puntos de cultura vienen de los niveles de edificios y de las celebraciones; hacen falta para fundar una nueva aldea."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I punti cultura provengono dai livelli degli edifici e dalle celebrazioni; servono per fondare un nuovo villaggio."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os pontos de cultura vêm dos níveis das construções e das celebrações; são necessários para fundar uma nova vila."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очки культуры дают уровни зданий и празднества; нужны для основания новой деревни."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "文化ポイントは建物レベルと祝祭から得られ、新しい村の建設に必要。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نقاط الثقافة تأتي من مستويات المباني والاحتفالات؛ وهي لازمة لتأسيس قرية جديدة."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "문화 점수는 건물 레벨과 축제에서 나옵니다; 새 마을을 세우는 데 필요합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文化点数来自建筑等级和庆典；建立新村庄时需要。"
          }
        }
      }
    },
