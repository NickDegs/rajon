          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 외교 관계가 없습니다. 적대 조직에 전쟁을 선포하거나 동맹을 제안하세요."
          }
        },
        "zh-Hans": {
