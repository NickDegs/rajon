{
  "sourceLanguage": "tr",
  "strings": {
    "⚠️ Sahada adamın yok. Önce 'Ekip'ten sahaya adam koy.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ No men in the field. Field men from 'Crew' first."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Keine Männer im Einsatz. Erst aus 'Crew' einsetzen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Sin hombres en campo. Despliega desde 'Equipo'."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Aucun homme déployé. Place-en depuis 'Équipe'."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Nessun uomo schierato. Schiera dalla 'Squadra'."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Sem homens em campo. Coloque pela 'Tropa'."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Нет бойцов в поле. Выставь их во вкладке «Команда»."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ لا رجال في الميدان. انشرهم من 'الطاقم'."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 出撃中の男がいない。まず『クルー』から。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 현장에 부하가 없습니다. 먼저 '팀'에서 현장에 부하를 배치하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 现场没有手下。请先从'队伍'派手下到现场。"
          }
        }
      }
    },
