    "Tüm dünyayla aynı sahada oyna — üssünü kur, fethet, baskın yap": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Play in one shared world — build, conquer, raid"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiele in einer Welt — bauen, erobern, überfallen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Juega en un mundo común — construye, conquista, asalta"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Joue dans un monde commun — construis, conquiers, pille"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gioca in un mondo unico — costruisci, conquista, saccheggia"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Jogue num mundo único — construa, conquiste, ataque"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Играй в едином мире — строй, захватывай, грабь"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "العب في عالم واحد — ابنِ، اغزُ، اغر"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一つの世界で対戦 — 建設・占領・襲撃"
          }
        }
      }
    },
    "Tüm ilerleme silinir, baştan başlarsın. Online hesabın kalır.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All progress is wiped; you start over. Your online account stays."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aller Fortschritt wird gelöscht; du fängst neu an. Online-Konto bleibt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se borra todo el progreso; empiezas de nuevo. Tu cuenta online queda."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toute la progression est effacée ; tu recommences. Ton compte en ligne reste."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti i progressi cancellati; ricominci. L'account online resta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo o progresso é apagado; recomeça. Sua conta online fica."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Весь прогресс стирается; начинаешь заново. Онлайн-аккаунт остаётся."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُمحى كل التقدّم؛ تبدأ من جديد. يبقى حسابك أونلاين."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進行はすべて消去、最初から。オンラインアカウントは残る。"
          }
        }
      }
    },
    "Tüm satın alımlar kozmetiktir, oyunu güçlendirmez.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All purchases are cosmetic and don't boost gameplay."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Käufe sind kosmetisch und stärken nicht."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas las compras son cosméticas y no potencian el juego."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tous les achats sont cosmétiques et n'avantagent pas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti gli acquisti sono estetici e non potenziano."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas as compras são cosméticas e não fortalecem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все покупки косметические и не усиливают игру."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كل المشتريات تجميلية ولا تقوّي اللعب."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "購入はすべて見た目だけで強化なし。"
          }
        }
      }
    },
