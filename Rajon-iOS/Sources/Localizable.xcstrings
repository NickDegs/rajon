    "Asker eğit, akına çık, yağma getir": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Train troops, raid, bring loot"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Truppen ausbilden, überfallen, Beute holen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrena, asalta, trae botín"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Entraîne, attaque, rapporte du butin"
