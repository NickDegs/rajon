    "Rakip çete üyelerine baskın yap → savaş puanı kazan.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Raid rival gang members → earn war points."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Überfalle gegnerische Bandenmitglieder → Kriegspunkte."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Asalta a miembros de la banda rival → gana puntos de guerra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pille les membres du gang rival → gagne des points de guerre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Saccheggia i membri della banda rivale → punti guerra."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ataque membros da gangue rival → ganhe pontos de guerra."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Граби членов вражеской банды → очки войны."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اغزُ أعضاء العصابة الخصم → اكسب نقاط الحرب."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "敵ギャングの構成員を襲撃 → 戦争ポイント獲得。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "상대 조직원에게 습격 → 전투 점수 획득."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
