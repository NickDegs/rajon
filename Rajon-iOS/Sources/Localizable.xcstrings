    "VIP'e özel: bir hayvan sahiplen, profilinde sergile. Mağaza'dan VIP edin.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "VIP-only: own a pet and show it on your profile. Get VIP in the Store."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur VIP: Halte ein Tier und zeig es im Profil. VIP im Shop."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo VIP: ten una mascota y muéstrala en tu perfil. Consigue VIP en la Tienda."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "VIP uniquement : adopte un animal et affiche-le. VIP en boutique."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo VIP: possiedi un animale e mostralo nel profilo. VIP nello Store."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Só VIP: tenha um mascote e exiba no perfil. VIP na Loja."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Только VIP: заведи питомца и покажи в профиле. VIP в магазине."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حصري لـ VIP: امتلك حيوانًا واعرضه في ملفك. احصل على VIP من المتجر."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "VIP限定：ペットを飼ってプロフィールに表示。ストアでVIP入手。"
          }
        }
      }
    },
