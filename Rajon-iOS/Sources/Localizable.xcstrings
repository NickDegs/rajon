          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mande o chefe num trampo, ganhe prêmios"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправь босса на дело, получи награду"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أرسل الزعيم لمهمة، احصل على مكافأة"
          }
        },
        "ja": {
