    "Parayı bas, sokaktan adam çek. Kimi it çıkar, kimi efsane — şansına.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pay up, pull a man off the street. Some are mutts, some legends — luck of the draw."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zahl und zieh einen von der Straße. Mal Köter, mal Legende — Glückssache."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Paga y saca un hombre de la calle. Unos perros, otros leyendas — suerte."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Paie et tire un homme de la rue. Parfois un cabot, parfois une légende — au hasard."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Paga e tira su un uomo dalla strada. Chi è un cane, chi una leggenda — fortuna."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pague e puxe um homem da rua. Uns são vira-latas, outros lendas — sorte."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Плати и тащи бойца с улицы. Кто шавка, кто легенда — как повезёт."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ادفع واسحب رجلاً من الشارع. منهم وضيع ومنهم أسطورة — حظّك."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "金を払い、街から男を引く。雑魚か伝説か — 運次第。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "돈을 뿌려 거리에서 인원을 모집하세요. 어떤 자는 잡졸, 어떤 자는 전설 — 운에 달렸습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "撒钱从街头招人。有的是废物，有的是传奇 — 全看你的运气。"
          }
        }
      }
    },
