    "Önce bir köy kur. Kervanlar ana üsten köylerine kaynak taşır.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Found a village first. Caravans haul resources from the main base to your villages."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gründe zuerst ein Dorf. Karawanen transportieren Ressourcen von der Hauptbasis zu deinen Dörfern."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fonde d'abord un village. Les caravanes acheminent des ressources de la base principale vers tes villages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Primero funda una aldea. Las caravanas llevan recursos desde la base principal a tus aldeas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prima fonda un villaggio. Le carovane portano risorse dalla base principale ai tuoi villaggi."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Primeiro funde uma vila. As caravanas levam recursos da base principal às suas vilas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сначала основай деревню. Караваны везут ресурсы с главной базы в твои деревни."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まず村を建てよう。隊商は拠点から村へ資源を運ぶ。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أسّس قرية أولًا. القوافل تنقل الموارد من القاعدة الرئيسية إلى قراك."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "먼저 마을을 세우세요. 대상(카라반)은 본부에서 마을로 자원을 운반합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先建立一个村庄。商队会从主基地向村庄运送资源。"
          }
        }
      }
    },
