    "Çeteleri tek tek dağıt, sokakları al. Ekibini güçlendirmeden ağırlara bulaşma.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Break gangs one by one and take the streets. Don't tangle with heavies before powering up."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zerschlag Banden einzeln und nimm die Straßen. Leg dich nicht mit Schweren an, bevor du stark bist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Rompe bandas una a una y toma las calles. No te metas con los duros sin reforzarte."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Brise les gangs un à un et prends la rue. Ne défie pas les costauds sans renfort."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Distruggi le bande una a una e prendi le strade. Non sfidare i pezzi grossi senza potenziarti."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quebre gangues uma a uma e tome as ruas. Não encare os fortes sem reforço."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разбивай банды по одной и захватывай улицы. Не лезь к тяжёлым, пока не усилишься."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حطّم العصابات واحدة تلو الأخرى وخذ الشوارع. لا تتورّط مع الكبار قبل أن تقوى."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ギャングを一つずつ潰し街路を奪え。強化前に大物に手を出すな。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "조직을 하나씩 해체하고 거리를 차지하라. 팀을 강화하기 전엔 거물들과 엮이지 마라."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "逐个瓦解帮派，占领街道。没强化队伍前别招惹大人物。"
          }
        }
      }
    },
