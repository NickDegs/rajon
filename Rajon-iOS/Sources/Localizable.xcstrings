    "Köyde savunma yok — garnizon gönder veya eğit.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No defense in the village — send a garrison or train."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Verteidigung im Dorf — schicke eine Garnison oder bilde aus."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune défense au village — envoie une garnison ou entraîne."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay defensa en la aldea — envía guarnición o entrena."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuna difesa nel villaggio — invia una guarnigione o addestra."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem defesa na vila — envie guarnição ou treine."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В деревне нет защиты — пошли гарнизон или обучи."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "村に防御なし — 駐留軍を送るか訓練を。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا دفاع في القرية — أرسل حامية أو درّب."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "마을에 방어가 없습니다 — 주둔군을 보내거나 훈련하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "村庄没有防御 — 派驻军或进行训练。"
          }
        }
      }
    },
