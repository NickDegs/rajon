    "Tüm dünyayla aynı sahada oyna — üssünü kur, fethet, baskın yap": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Play in one shared world — build, conquer, raid"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiele in einer Welt — bauen, erobern, überfallen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Juega en un mundo común — construye, conquista, asalta"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Joue dans un monde commun — construis, conquiers, pille"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gioca in un mondo unico — costruisci, conquista, saccheggia"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Jogue num mundo único — construa, conquiste, ataque"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Играй в едином мире — строй, захватывай, грабь"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "العب في عالم واحد — ابنِ، اغزُ، اغر"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一つの世界で対戦 — 建設・占領・襲撃"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전 세계와 같은 현장에서 플레이하세요 — 기지를 세우고, 정복하고, 습격하세요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "与全世界在同一战场对战 — 建立你的基地、征服、袭击"
          }
        }
      }
    },
    "Tüm ilerleme silinir, baştan başlarsın. Online hesabın kalır.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All progress is wiped, you start over. Your online account stays."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der gesamte Fortschritt wird gelöscht, du fängst von vorn an. Dein Online-Konto bleibt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se borra todo el progreso, empiezas de cero. Tu cuenta online se mantiene."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toute la progression est effacée, tu recommences. Ton compte en ligne est conservé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti i progressi vengono cancellati, ricominci da capo. Il tuo account online resta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo o progresso é apagado, você começa do zero. Sua conta online permanece."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Весь прогресс удаляется, начнёшь заново. Онлайн-аккаунт сохранится."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُحذف كل التقدم وتبدأ من جديد. يبقى حسابك على الأونلاين."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "全進行状況が削除され、最初からやり直し。オンラインアカウントは残る。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 진행 상황이 삭제되고 처음부터 시작합니다. 온라인 계정은 유지됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有进度将被清除，你将从头开始。你的在线账户会保留。"
          }
        }
      }
    },
    "Tüm satın alımlar kozmetiktir, oyunu güçlendirmez.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All purchases are cosmetic and don't make the game stronger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Käufe sind kosmetisch und machen das Spiel nicht stärker."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas las compras son cosméticas, no potencian el juego."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tous les achats sont cosmétiques et ne renforcent pas le jeu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti gli acquisti sono cosmetici, non potenziano il gioco."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas as compras são cosméticas, não fortalecem o jogo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все покупки косметические, не усиливают игру."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كل المشتريات تجميلية ولا تقوّي اللعب."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "全ての購入はコスメティックで、ゲームを強化しない。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 구매는 장식용이며 게임을 강화하지 않습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有购买均为装饰性，不会增强游戏实力。"
          }
        }
      }
    },
