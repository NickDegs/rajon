        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No enemy base to conquer nearby. Rivals will appear here as they grow."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine feindliche Basis in der Nähe zum Erobern. Rivalen erscheinen hier, wenn sie wachsen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune base ennemie à conquérir à proximité. Les rivaux apparaîtront ici à mesure qu'ils grandiront."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay base enemiga por conquistar cerca. Aparecerán aquí a medida que los rivales crezcan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuna base nemica da conquistare nelle vicinanze. Appariranno qui man mano che i rivali crescono."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não há base inimiga a conquistar por perto. Vão aparecer aqui conforme os rivais crescem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поблизости нет вражеской базы для захвата. Соперники появятся здесь по мере роста."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "近くに征服できる敵拠点はない。ライバルが成長するとここに現れる。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا قاعدة عدوّة قريبة للغزو. سيظهر الخصوم هنا كلما كبروا."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "곧 정복할 수 있는 적 기지가 없습니다. 상대가 성장하면 여기에 나타납니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂无可征服的敌方基地。对手成长后会出现在这里。"
          }
        }
      }
    },
